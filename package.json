{
  "name": "dokuma",
  "version": "0.0.6",
  "description": "Framework-agnostic, zero-dependency headless UI primitives — works in vanilla HTML/CDN, React, Vue, Svelte, Solid, Angular, and native mobile shells. Pure TypeScript, tree-shakeable, SSR-safe, accessibility-first.",
  "keywords": [
    "a11y",
    "accessible",
    "agnostic",
    "angular",
    "aria",
    "cdn",
    "dokuma",
    "esm",
    "framework-agnostic",
    "headless",
    "headless-ui",
    "lit",
    "mobile",
    "native",
    "preact",
    "primitives",
    "qwik",
    "react",
    "solid",
    "ssr",
    "ssr-safe",
    "svelte",
    "tree-shakeable",
    "typescript",
    "ui",
    "vanilla",
    "vue",
    "wai-aria",
    "web-components",
    "zero-dependency"
  ],
  "homepage": "https://github.com/productdevbook/dokuma",
  "bugs": {
    "url": "https://github.com/productdevbook/dokuma/issues"
  },
  "license": "MIT",
  "author": "productdevbook",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/productdevbook/dokuma.git"
  },
  "funding": "https://github.com/sponsors/productdevbook",
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./vanilla": {
      "types": "./dist/adapters/vanilla.d.mts",
      "default": "./dist/adapters/vanilla.mjs"
    },
    "./react": {
      "types": "./dist/adapters/react.d.mts",
      "default": "./dist/adapters/react.mjs"
    },
    "./react-hooks": {
      "types": "./dist/adapters/react-hooks.d.mts",
      "default": "./dist/adapters/react-hooks.mjs"
    },
    "./vue": {
      "types": "./dist/adapters/vue.d.mts",
      "default": "./dist/adapters/vue.mjs"
    },
    "./vue-composables": {
      "types": "./dist/adapters/vue-composables.d.mts",
      "default": "./dist/adapters/vue-composables.mjs"
    },
    "./accordion": {
      "types": "./dist/primitives/accordion.d.mts",
      "default": "./dist/primitives/accordion.mjs"
    },
    "./avatar": {
      "types": "./dist/primitives/avatar.d.mts",
      "default": "./dist/primitives/avatar.mjs"
    },
    "./checkbox": {
      "types": "./dist/primitives/checkbox.d.mts",
      "default": "./dist/primitives/checkbox.mjs"
    },
    "./combobox": {
      "types": "./dist/primitives/combobox.d.mts",
      "default": "./dist/primitives/combobox.mjs"
    },
    "./context-menu": {
      "types": "./dist/primitives/context-menu.d.mts",
      "default": "./dist/primitives/context-menu.mjs"
    },
    "./dialog": {
      "types": "./dist/primitives/dialog.d.mts",
      "default": "./dist/primitives/dialog.mjs"
    },
    "./disclosure": {
      "types": "./dist/primitives/disclosure.d.mts",
      "default": "./dist/primitives/disclosure.mjs"
    },
    "./menu": {
      "types": "./dist/primitives/menu.d.mts",
      "default": "./dist/primitives/menu.mjs"
    },
    "./popover": {
      "types": "./dist/primitives/popover.d.mts",
      "default": "./dist/primitives/popover.mjs"
    },
    "./progress": {
      "types": "./dist/primitives/progress.d.mts",
      "default": "./dist/primitives/progress.mjs"
    },
    "./radio-group": {
      "types": "./dist/primitives/radio-group.d.mts",
      "default": "./dist/primitives/radio-group.mjs"
    },
    "./slider": {
      "types": "./dist/primitives/slider.d.mts",
      "default": "./dist/primitives/slider.mjs"
    },
    "./switch": {
      "types": "./dist/primitives/switch.d.mts",
      "default": "./dist/primitives/switch.mjs"
    },
    "./tabs": {
      "types": "./dist/primitives/tabs.d.mts",
      "default": "./dist/primitives/tabs.mjs"
    },
    "./toaster": {
      "types": "./dist/primitives/toaster.d.mts",
      "default": "./dist/primitives/toaster.mjs"
    },
    "./toggle": {
      "types": "./dist/primitives/toggle.d.mts",
      "default": "./dist/primitives/toggle.mjs"
    },
    "./toggle-group": {
      "types": "./dist/primitives/toggle-group.d.mts",
      "default": "./dist/primitives/toggle-group.mjs"
    },
    "./tooltip": {
      "types": "./dist/primitives/tooltip.d.mts",
      "default": "./dist/primitives/tooltip.mjs"
    }
  },
  "scripts": {
    "build": "node scripts/sync-exports.mjs && obuild",
    "sync-exports": "node scripts/sync-exports.mjs",
    "dev": "vitest",
    "lint": "oxlint . && oxfmt --check .",
    "lint:fix": "oxlint . --fix && oxfmt .",
    "fmt": "oxfmt .",
    "test": "pnpm lint && pnpm typecheck && vitest run",
    "typecheck": "tsgo --noEmit",
    "bundle-budget": "node scripts/bundle-budget.mjs",
    "docs": "node docs/serve.mjs",
    "attw": "pnpm dlx @arethetypeswrong/cli --pack . --profile esm-only",
    "release": "pnpm test && pnpm build && pnpm bundle-budget && pnpm attw && bumpp --commit --tag --push --all",
    "prepack": "pnpm build"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "@vitest/coverage-v8": "^4.1.2",
    "bumpp": "^11.0.1",
    "jsdom": "^29.0.2",
    "obuild": "^0.4.32",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "react": "^19.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "vue": "^3.5.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  }
}
